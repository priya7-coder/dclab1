        "#1. Linearity Check : y[n] = x[n] - x[n-1]\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "\n"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "def system_operator(x):\n",
        "\n",
        "# We need x[-1] for n=0, so pad the input with a leading zero.\n",
        "  x_padded = np.concatenate(([0], x))\n",
        "  y = np.zeros(len(x))\n",
        "  for n in range(1, len(x_padded)):\n",
        "   y[n-1] = x_padded[n] - x_padded[n-1]\n",
        "  return y\n",
        "# 1. Define a test signal\n",
        "n = np.arange(10)\n",
        "x1 = np.sin(2 * np.pi * n / 5) # A simple sine wave\n",
        "x2 = np.cos(2 * np.pi * n / 10) # Another signal\n",
        "\n",
        "# --- Testing for Linearity ---\n",
        "print(\"--- Testing Linearity ---\")\n",
        "print(f\"Input x1: {x1.round(2)}\")\n",
        "print(f\"Output y1 (H[x1]): {system_operator(x1).round(2)}\")\n",
        "print(f\"\\nInput x2: {x2.round(2)}\")\n",
        "print(f\"Output y2 (H[x2]): {system_operator(x2).round(2)}\")\n",
        "# Test additivity and homogeneity together\n",
        "a, b = 2, 3 # Choose any scalars\n",
        "x_sum = a * x1 + b * x2\n",
        "y_sum = system_operator(x_sum)\n",
        "\n",
        "# The linearity condition is: H[a*x1 + b*x2] == a*H[x1] + b*H[x2]\n",
        "\n",
        "linearity_rhs = a * system_operator(x1) + b * system_operator(x2)\n",
        "print(f\"\\nLinearity Test: H[a*x1 + b*x2] = {y_sum.round(2)}\")\n",
        "print(f\"a*H[x1] + b*H[x2] = {linearity_rhs.round(2)}\")\n",
        "if np.allclose(y_sum, linearity_rhs):\n",
        "      print(\"The system appears to be LINEAR for this test.\")\n",
        "else:\n",
        "      print(\"The system appears to be NON-LINEAR for this test.\")\n"
      ],
